# Twitch App credentials — https://dev.twitch.tv/console/apps
# Needed for: real viewer counts, live/offline detection in the stat band
# Without these the app falls back to the mock values in MOCK_STREAMERS.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Set to 1 to ship a live-only build for a client: the Live/Demo switch is hidden and the app
# stays in live mode (demo channels never load). Leave unset to keep the Demo feature.
NEXT_PUBLIC_DEMO_DISABLED=

# Set to 1 to expose the internal /showcase page (every view/panel/admin/overlay in one page).
# Server-only gate, read at request time — restart the dev server after changing it.
SHOWCASE_ENABLED=

# X live chat (extension). Shared key the MarketBubble Chat Bridge extension uses to POST chat
# to /api/x/chat. The extension is the first-class X source (also covers Spaces).
X_CHAT_API_KEY=

# X broadcast bridge (server-side, automatic, no extension). Primary config is each streamer's
# "xBroadcasts" in streamers.json (their own X plus a shared show account like MarketBubble);
# shared accounts are de-duplicated across the roster. This env var is ADDITIVE to that, for hosts
# that can't edit the file. Comma-separated @handles and/or broadcast links. Anonymous/read-only.
#   X_BROADCAST_SOURCES="MarketBubble,https://x.com/i/broadcasts/1AbCdEfGhIjKl"
X_BROADCAST_SOURCES=
# Optional overrides if X rotates these (rarely needed):
#   X_WEB_BEARER=            public web bearer token
#   X_GQL_USER_BY_SCREEN_NAME=  UserByScreenName query id
#   X_GQL_USER_TWEETS=          UserTweets query id
