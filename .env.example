# Copy to .env before: docker compose up --build -d
# cp .env.example .env

# ── Public URL (required for production) ─────────────────────────────────────
# Used at image build time (Open Graph, sitemap) and for relay CORS.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Hide the Demo toggle in the UI (recommended for production). Baked in at build time.
NEXT_PUBLIC_DEMO_DISABLED=1

# Host port for the dashboard (reverse-proxy to this, or expose directly)
APP_PORT=3000

# CORS origin for the relay (defaults to NEXT_PUBLIC_SITE_URL)
# RELAY_ALLOW_ORIGIN=https://your-domain.com

# ── Twitch (recommended) ─────────────────────────────────────────────────────
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ── Relay: which channels to tally for the leaderboard ─────────────────────
# Comma-separated Twitch logins probed when Helix creds are absent.
RELAY_CHANNELS=fazebanks

# Kick chat tallying (optional). Chatroom id is required — lookup may fail behind Cloudflare.
# RELAY_KICK_CHATROOM_ID=
# RELAY_KICK_CHANNEL=fazebanks

# ── X chat ───────────────────────────────────────────────────────────────────
# Extension → POST /api/x/chat (generate: openssl rand -hex 32)
X_CHAT_API_KEY=

# Extra broadcast sources for the server bridge (additive to xBroadcasts in streamers.json)
# X_BROADCAST_SOURCES=MarketBubble

# Optional if X rotates GraphQL query ids:
# X_WEB_BEARER=
# X_GQL_USER_BY_SCREEN_NAME=
# X_GQL_USER_TWEETS=

# ── Optional ─────────────────────────────────────────────────────────────────
# X_MENTION_QUERIES=MarketBubble,crypto
# STREAMERS_JSON=[{"id":"...","name":"...","handles":{"twitch":"..."},"platforms":["twitch"]}]
