# Copy to .env before: docker compose up --build -d
# cp .env.example .env

# ── Public URL (required for production) ─────────────────────────────────────
# Used at image build time (Open Graph, sitemap) and for relay CORS.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Hide the Demo toggle in the UI (recommended for production). Baked in at build time.
NEXT_PUBLIC_DEMO_DISABLED=1

# Host port for the dashboard (reverse-proxy to this, or expose directly)
APP_PORT=3000

# CORS origin for the relay (defaults to NEXT_PUBLIC_SITE_URL)
# RELAY_ALLOW_ORIGIN=https://your-domain.com

# ── Twitch (recommended) ─────────────────────────────────────────────────────
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Clip radar: user token with the clips:edit scope (any account — it can clip any live channel
# that allows clips). Without it the radar still records moments, it just can't cut clips.
# TWITCH_CLIP_TOKEN=

# ── Relay: which channels to tally for the leaderboard ─────────────────────
# Comma-separated Twitch logins probed when Helix creds are absent.
RELAY_CHANNELS=fazebanks

# Kick chat tallying (optional). Chatroom id is required — lookup may fail behind Cloudflare.
# RELAY_KICK_CHATROOM_ID=
# RELAY_KICK_CHANNEL=fazebanks

# ── X chat ───────────────────────────────────────────────────────────────────
# Extension → POST /api/x/chat (generate: openssl rand -hex 32)
X_CHAT_API_KEY=

# Extra broadcast sources for the server bridge (additive to xBroadcasts in streamers.json)
# X_BROADCAST_SOURCES=MarketBubble

# Optional if X rotates GraphQL query ids:
# X_WEB_BEARER=
# X_GQL_USER_BY_SCREEN_NAME=
# X_GQL_USER_TWEETS=

# ── Optional ─────────────────────────────────────────────────────────────────
# X_MENTION_QUERIES=MarketBubble,crypto
# STREAMERS_JSON=[{"id":"...","name":"...","handles":{"twitch":"..."},"platforms":["twitch"]}]

# ── Database (optional) ──────────────────────────────────────────────────────
# SQLite persistence via Node's built-in driver — no extra service, no dependency.
# When set: admin control-plane state (announcement, flags, roster override, chat
# filters, the active poll and its votes) survives restarts; the leaderboard turns
# all-time (counts accumulate across app/relay restarts); and viewer history is
# sampled every minute while live, powering the admin Health tab's graphs.
# Leave unset to run fully in-memory: identical live features, state resets with
# the process and the history graphs are disabled.
# With docker compose, /data is a persistent volume — this path just works:
# DATABASE_PATH=/data/marketbubble.db

# ── AI assistant (optional) ────────────────────────────────────────────────────
# Server-held provider keys. When set, that provider shows as "Active · server" in
# Settings → Assistant, is locked in the UI, and calls go through /api/assistant/proxy
# (the key never reaches the browser). Leave unset to require bring-your-own-key.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# XAI_API_KEY=
# OPENROUTER_API_KEY=
# Per-visitor limits for the shared server keys (defaults: 5/min, 50/day).
# ASSISTANT_RPM=5
# ASSISTANT_RPD=50
# Ship without the assistant entirely:
# NEXT_PUBLIC_AI_DISABLED=1

# ── Admin board (optional) ─────────────────────────────────────────────────────
# /admin: live show controls pushed to every viewer over SSE — announcements, polls
# (site + chat voting), streamer roster with pinning, global chat filters, feature
# flags, health status. Auth key:
# ADMIN_API_KEY, falling back to X_CHAT_API_KEY (same key the extension uses).
# ADMIN_API_KEY=
# Remove the admin board entirely (the route 404s):
# ADMIN_DISABLED=1
